# Botlanes environment overrides
# Copy to .env and uncomment lines you want to customize.
# Most users don't need any of these — botlanes auto-detects your setup.

# Override Claude CLI config directory (default: $CLAUDE_CONFIG_DIR or ~/.claude)
# BOTLANES_CLAUDE_CONFIG_DIR=/path/to/.claude

# Override Claude CLI binary path (default: "claude" from $PATH)
# BOTLANES_CLAUDE_BIN=/path/to/claude

# Override Gemini CLI binary path (default: "gemini" from $PATH)
# BOTLANES_GEMINI_BIN=/path/to/gemini

# Agent timeout in seconds (default: 1800 = 30 minutes)
# BOTLANES_AGENT_TIMEOUT_SECONDS=1800

# Fixed port for debugging (default: random 10000-60000)
# BOTLANES_PORT=12345

# Base path for reverse proxy deployments (e.g., /botlanes)
# BOTLANES_BASE_PATH=

# Password for board access (default: none — open access)
# MISSION_CONTROL_PASSWORD=
